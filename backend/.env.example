# Rename this file to .env before running the server

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/darshanease
# Atlas:  mongodb+srv://<user>:<password>@cluster0.mongodb.net/darshanease
MONGO_URI=mongodb://127.0.0.1:27017/darshanease

# JWT secret key (use a long random string in production)
JWT_SECRET=darshanease_super_secret_key_change_this

# JWT token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:3000
